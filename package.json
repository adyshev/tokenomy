{
  "name": "tokenomy-pi",
  "version": "0.1.2-beta",
  "description": "Project-local Pi extension that routes Codex prompts by complexity and confidence.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "codex",
    "routing",
    "token-economy"
  ],
  "files": [
    ".pi/extensions/tokenomy/index.ts",
    ".pi/tokenomy.json",
    "README.md",
    "INSTALL.md",
    "CONFIG.md",
    "COMPATIBILITY.md",
    "LIMITATIONS.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "test": "node --experimental-strip-types --loader ./tests/pi-extension-loader.mjs --test tests/*.test.mjs",
    "json:check": "node -e \"for (const f of ['.pi/tokenomy.json','.pi/settings.json','package.json']) JSON.parse(require('fs').readFileSync(f,'utf8')); console.log('json ok')\"",
    "pi:check": "pi --offline --approve --no-session --list-models openai-codex"
  },
  "pi": {
    "extensions": [
      ".pi/extensions/tokenomy/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adyshev/tokenomy.git"
  },
  "bugs": {
    "url": "https://github.com/adyshev/tokenomy/issues"
  },
  "homepage": "https://github.com/adyshev/tokenomy#readme",
  "publishConfig": {
    "access": "public"
  }
}
